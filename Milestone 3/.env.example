PORT=3000
OTP_SECRET=replace-with-a-random-secret
OTP_LENGTH=6
OTP_TTL_MINUTES=5
MAX_VERIFY_ATTEMPTS=5
MIN_SECONDS_BETWEEN_SENDS=45
SESSION_SECRET=replace-with-a-long-random-session-secret
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=fitplanai

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=no-reply@fitplanai.com
SMTP_PASS=your-smtp-password-or-api-key
SMTP_FROM=FitPlan AI <no-reply@fitplanai.com>
SMTP_SECURE=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
